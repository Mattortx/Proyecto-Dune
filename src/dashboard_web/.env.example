# Copia este archivo a .env y rellena los valores reales.

# Firebase (Firestore)
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
FIREBASE_COLLECTIONS=dashboard_items|users|games
# Compatibilidad retro: FIREBASE_COLLECTION (si no usas FIREBASE_COLLECTIONS)
FIREBASE_COLLECTION=dashboard_items
FIREBASE_LIMIT=10

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
SUPABASE_TABLES=table_a|table_b
# Compatibilidad retro: SUPABASE_TABLE (si no usas SUPABASE_TABLES)
SUPABASE_TABLE=dashboard_items
SUPABASE_LIMIT=10

# Neon (PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEON_TABLES=clientes|marketing_document_segments
# Compatibilidad retro: NEON_TABLE (si no usas NEON_TABLES)
NEON_TABLE=dashboard_items
NEON_LIMIT=10

# Neon REST opcional (si usas endpoint /rest/v1 en lugar de conexión PostgreSQL)
NEON_REST_URL=https://your-neon-host/neondb/rest/v1
NEON_REST_KEY=your-neon-rest-api-key
NEON_REST_SCHEMA=public
